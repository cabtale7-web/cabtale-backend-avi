    "event":  [
                  {
                      "listen":  "prerequest",
                      "script":  {
                                     "type":  "text/javascript",
                                     "exec":  [
                                                  "let phone = pm.collectionVariables.get(\u0027customer_phone\u0027);",
                                                  "if (!phone) {",
                                                  "  const ts = Date.now().toString();",
                                                  "  phone = \u00277\u0027 + ts.slice(-9);",
                                                  "  pm.collectionVariables.set(\u0027customer_phone\u0027, phone);",
                                                  "}",
                                                  "let email = pm.collectionVariables.get(\u0027customer_email\u0027);",
                                                  "if (!email) {",
                                                  "  const ts = Date.now().toString();",
                                                  "  email = `postman.customer.${ts}@example.com`;",
                                                  "  pm.collectionVariables.set(\u0027customer_email\u0027, email);",
                                                  "}"
                                              ]
                                 }
                  }
              ],
