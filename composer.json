{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": ["framework", "laravel"],
    "license": "MIT",
   "require": {
        "php": "^8.2",
        "barryvdh/laravel-dompdf": "^2.0",
        "brian2694/laravel-toastr": "^5.57",
        "cboden/ratchet": "^0.4.4",
        "doctrine/dbal": "^3.6",
        "google/cloud-storage": "^1.49",
        "guzzlehttp/guzzle": "^7.0.1",
        "illuminate/database": "^10.10",
        "laravel/framework": "^10.10",
        "laravel/passport": "^11.0",
        "laravel/sanctum": "^3.3",
        "laravel/tinker": "^2.8",
        "lcobucci/clock": "^3.3",
        "lcobucci/jwt": "^5.5",
        "madnest/madzipper": "^1.4",
        "matanyadaev/laravel-eloquent-spatial": "^4.0",
        "mercadopago/dx-php": "^2.4",
        "mpdf/mpdf": "^8.1",
        "nwidart/laravel-modules": "^10.0",
        "openspout/openspout": "^4.28",
        "pusher/pusher-php-server": "^7.2",
        "rap2hpoutre/fast-excel": "^5.3",
        "razorpay/razorpay": "^2.9",
        "react/promise": "^3.1",
        "resend/resend-laravel": "^1.3",
        "spatie/db-dumper": "^3.4",
        "spatie/laravel-google-cloud-storage": "2.3",
        "stevebauman/location": "^7.1",
        "stripe/stripe-php": "^13.9",
        "twilio/sdk": "^7.14",
        "unicodeveloper/laravel-paystack": "^1.1",
        "xendit/xendit-php": "^4.1"
    }

,
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "Modules\\": "Modules/"
        },
        "files": [
            "app/Lib/Helpers.php",
            "app/Lib/Constant.php",
            "app/Lib/Response.php",
            "app/Lib/QueryInterface.php",
            "Modules/ZoneManagement/Lib/Zone.php",
            "Modules/PromotionManagement/Lib/Promotion.php",
            "Modules/BusinessManagement/Lib/BusinessSettingType.php",
            "Modules/Gateways/Library/Constant.php",
            "app/Library/order.php",
            "app/Library/TripRequestUpdate.php",
            "app/Library/CCavenue/Crypto.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "wikimedia/composer-merge-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.16",
        "laravel/sail": "^1.46",
        "nunomaduro/collision": "^7.12",
        "spatie/laravel-ignition": "^2.9"
    }
}
